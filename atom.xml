    <content type="html"><![CDATA[<h1 id="Python"><a href="#Python" class="headerlink" title="Python"></a>Python</h1><p>​    <code>print(&quot;Hello World&quot;)</code></p><h1 id="C"><a href="#C" class="headerlink" title="C"></a>C</h1><p>​    <code>printf(&quot;Hello World&quot;)</code></p><h1 id="Javascript"><a href="#Javascript" class="headerlink" title="Javascript"></a>Javascript</h1><p>​    <code>console.log(&quot;Hello World&quot;)</code></p><h1 id="C-1"><a href="#C-1" class="headerlink" title="C++"></a>C++</h1><p>​    <code>cout&lt;&lt;&quot;Hello World&quot;&lt;&lt;endl</code></p><h1 id="Java"><a href="#Java" class="headerlink" title="Java"></a>Java</h1><p>​    <code>System.out.println(&quot;Hello World&quot;)</code></p><h1 id="C-2"><a href="#C-2" class="headerlink" title="C#"></a>C#</h1><p>​    <code>Console.WriteLine(&quot;Hello World&quot;)</code></p><h1 id="PHP"><a href="#PHP" class="headerlink" title="PHP"></a>PHP</h1><p>​    <code>echo &quot;Hello World&quot;</code></p><h1 id="Scala"><a href="#Scala" class="headerlink" title="Scala"></a>Scala</h1><p>​    <code>println(&quot;Hello World&quot;)</code></p>]]></content>
    
